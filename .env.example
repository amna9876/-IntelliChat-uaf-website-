# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # change to "production" when deploying

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the JSON database file (relative to project root)
DB_PATH=./database/uaf.json

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  your actual domain, e.g. https://uaf-portal.onrender.com
ALLOWED_ORIGIN=http://localhost:3000
